{
  "SYNTAX": "MOSDEX/MOSDEX v2-0/MOSDEXSchemaV2-0.json",
  "MODULES": [
    {
      "NAME": "sailco",
      "CLASS": "MODULE",
      "KIND": "MODEL",
      "HEADING": {
        "DESCRIPTION": [
          "Inventory problem with lagged decision variables"
        ],
        "VERSION": [
          "2-0"
        ],
        "REFERENCE": [
          "https://www.ibm.com/support/knowledgecenter/SSSA5P_12.7.1/ilog.odms.ide.help/OPL_Studio/opllanguser/topics/opl_languser_app_areas_pwl_inventory.html"
        ],
        "AUTHOR": [
          "Jeremy A. Bloom (jeremyblmca@gmail.com)"
        ],
        "NOTICES": [
          "Copyright 2019 Jeremy A. Bloom"
        ],
        "MATH": [
          "minimize TotalCost",
          "subject to {",
          "forall( t in Periods )",
          "ctCapacity[t]: Regular[t] <= Capacity;",
          "forall( t in Periods )",
          "ctBoat[t]:",
          "Inventory[t]  + Regular[t] + Extra[t] == Inventory[t-1] - Demand[t];",
          "forall( t in Periods)",
          "ctCost[t]:",
          "Cost[t] - RegularCost * Regular[t] - ExtraCost * Extra[t] - InventoryCost * Inventory[t] == 0.0 ",
          "ctTotalCost:",
          "TotalCost - sum ( t in Periods) Cost[t] == 0.0",
          "}"
        ]
      },
      "TABLES": [
        {
          "NAME": "demands",
          "CLASS": "DATA",
          "KIND": "INPUT",
          "SCHEMA": {
            "NAME": [
              "period",
              "ancestor",
              "demand"
            ],
            "KIND": [
              "INTEGER",
              "INTEGER",
              "DOUBLE"
            ],
            "KEYS": [
              "period"
            ]
          },
          "INSTANCE": [
            [
              1,
              0,
              40.0
            ],
            [
              2,
              1,
              60.0
            ],
            [
              3,
              2,
              75.0
            ],
            [
              4,
              3,
              25.0
            ]
          ]
        },
        {
          "NAME": "parameters",
          "CLASS": "DATA",
          "KIND": "INPUT",
          "SCHEMA": {
            "NAME": [
              "regularCost",
              "extraCost",
              "capacity",
              "initialInventory",
              "inventoryCost"
            ],
            "KIND": [
              "DOUBLE",
              "DOUBLE",
              "DOUBLE",
              "DOUBLE",
              "DOUBLE"
            ]
          },
          "INSTANCE": [
            [
              400.0,
              450.0,
              40.0,
              10.0,
              20.0
            ]
          ]
        },
        {
          "NAME": "regular",
          "CLASS": "VARIABLE",
          "KIND": "CONTINUOUS",
          "SCHEMA": {
            "NAME": [
              "Name",
              "period",
              "Column",
              "LowerBound",
              "UpperBound",
              "value"
            ],
            "KIND": [
              "STRING",
              "INTEGER",
              "STRING",
              "DOUBLE",
              "DOUBLE",
              "DOUBLE"
            ],
            "KEYS": [
              "Name",
              "period"
            ],
            "FOREIGN_KEYS": [
              {
                "period": "demands.period"
              }
            ]
          },
          "QUERY": {
            "SELECT": [
              "'regular' AS Name                        -- STRING",
              "demands.period AS period                 -- INTEGER",
              "CONCAT('regular','_', demands.period) AS Column  -- STRING",
              "CAST(0.0 AS DOUBLE) AS LowerBound        -- DOUBLE",
              "CAST('Infinity' AS DOUBLE) AS UpperBound -- DOUBLE",
              "'PrimalValue(Column)' AS value           -- DOUBLE_FUNCTION"
            ],
            "FROM": [
              "demands"
            ]
          }
        },
        {
          "NAME": "extra",
          "CLASS": "VARIABLE",
          "KIND": "CONTINUOUS",
          "SCHEMA": {
            "NAME": [
              "Name",
              "period",
              "Column",
              "LowerBound",
              "UpperBound",
              "value"
            ],
            "KIND": [
              "STRING",
              "INTEGER",
              "STRING",
              "DOUBLE",
              "DOUBLE",
              "DOUBLE"
            ],
            "KEYS": [
              "Name",
              "period"
            ],
            "FOREIGN_KEYS": [
              {
                "period": "demands.period"
              }
            ]
          },
          "QUERY": {
            "SELECT": [
              "'extra' AS Name                          -- STRING",
              "demands.period AS period                 -- INTEGER",
              "CONCAT('extra','_', demands.period) AS Column    -- STRING",
              "CAST(0.0 AS DOUBLE) AS LowerBound        -- DOUBLE",
              "CAST('Infinity' AS DOUBLE) AS UpperBound -- DOUBLE",
              "'PrimalValue(Column)' AS value           -- DOUBLE_FUNCTION"
            ],
            "FROM": [
              "demands"
            ]
          }
        },
        {
          "NAME": "inventory",
          "CLASS": "VARIABLE",
          "KIND": "CONTINUOUS",
          "SCHEMA": {
            "NAME": [
              "Name",
              "period",
              "Column",
              "LowerBound",
              "UpperBound",
              "value"
            ],
            "KIND": [
              "STRING",
              "INTEGER",
              "STRING",
              "DOUBLE",
              "DOUBLE",
              "DOUBLE"
            ],
            "KEYS": [
              "Name",
              "period"
            ],
            "FOREIGN_KEYS": [
              {
                "period": "demands.period"
              }
            ]
          },
          "QUERY": {
            "SELECT": [
              "'inventory' AS Name                        -- STRING",
              "demands.period AS period                   -- INTEGER",
              "CONCAT('inventory','_', demands.period) AS Column  -- STRING",
              "CAST(0.0 AS DOUBLE) AS LowerBound          -- DOUBLE",
              "CAST('Infinity' AS DOUBLE) AS UpperBound   -- DOUBLE",
              "'PrimalValue(Column)' AS value             -- DOUBLE_FUNCTION"
            ],
            "FROM": [
              "demands"
            ],
            "INSERT": [
              "(",
              "'inventory',",
              " 0,",
              " CONCAT('inventory', '_', 0),",
              " parameters.initialInventory,",
              " parameters.initialInventory,",
              " parameters.initialInventory",
              ")"
            ]
          }
        },
        {
          "NAME": "cost",
          "CLASS": "VARIABLE",
          "KIND": "CONTINUOUS",
          "SCHEMA": {
            "NAME": [
              "Name",
              "period",
              "Column",
              "LowerBound",
              "UpperBound",
              "value"
            ],
            "KIND": [
              "STRING",
              "INTEGER",
              "STRING",
              "DOUBLE",
              "DOUBLE",
              "DOUBLE"
            ],
            "KEYS": [
              "Name",
              "period"
            ],
            "FOREIGN_KEYS": [
              {
                "period": "demands.period"
              }
            ]
          },
          "QUERY": {
            "SELECT": [
              "'cost' AS Name                          -- STRING",
              "demands.period AS period                 -- INTEGER",
              "CONCAT('cost','_', demands.period) AS Column    -- STRING",
              "CAST(0.0 AS DOUBLE) AS LowerBound        -- DOUBLE",
              "CAST('Infinity' AS DOUBLE) AS UpperBound -- DOUBLE",
              "'PrimalValue(Column)' AS value           -- DOUBLE_FUNCTION"
            ],
            "FROM": [
              "demands"
            ]
          }
        },
        {
          "NAME": "totalCost",
          "CLASS": "VARIABLE",
          "KIND": "CONTINUOUS",
          "SCHEMA": {
            "NAME": [
              "Name",
              "period",
              "Column",
              "LowerBound",
              "UpperBound",
              "value"
            ],
            "KIND": [
              "STRING",
              "INTEGER",
              "STRING",
              "DOUBLE",
              "DOUBLE",
              "DOUBLE"
            ],
            "KEYS": [
              "Name",
              "period"
            ],
            "FOREIGN_KEYS": [
              {
                "period": "demands.period"
              }
            ]
          },
          "QUERY": {
            "SELECT": [
              "'total_cost' AS Name                          -- STRING",
              "period  AS period                           -- INTEGER",
              "CONCAT('total_cost','_', demands.period) AS Column    -- STRING",
              "CAST(0.0 AS DOUBLE) AS LowerBound        -- DOUBLE",
              "CAST('Infinity' AS DOUBLE) AS UpperBound -- DOUBLE",
              "'PrimalValue(Column)' AS value           -- DOUBLE_FUNCTION"
            ],
            "FROM": [
              "demands"
            ],
            "WHERE": [
              "period = (SELECT MAX(period) FROM demands)"
            ]
          }
        },
        {
          "NAME": "ctCapacity",
          "CLASS": "CONSTRAINT",
          "KIND": "LINEAR",
          "SCHEMA": {
            "NAMES": [
              "Name",
              "period",
              "Row",
              "Sense",
              "RHS",
              "dual"
            ],
            "KIND": [
              "STRING",
              "INTEGER",
              "STRING",
              "STRING",
              "DOUBLE",
              "DOUBLE"
            ],
            "KEYS": [
              "Name",
              "period"
            ],
            "FOREIGN_KEYS": [
              {
                "period": "demands.period"
              }
            ],
            "RELATIONSHIP": [
              {
                "RHS": "parameters.capacity"
              }
            ]
          },
          "QUERY": {
            "SELECT": [
              "'ctCapacity' AS Name                     -- STRING",
              "demands.period AS period                  -- INTEGER",
              "CONCAT('ctCapacity','_', demands.period) AS Row  -- STRING",
              "'<=' AS Sense                            -- STRING",
              "parameters.capacity AS RHS               -- DOUBLE",
              "'DualValue(Row)' AS dual                -- DOUBLE_FUNCTION",
              "CAST(1.0 AS DOUBLE) AS regular_coeff          -- DOUBLE "
            ],
            "FROM": [
              "demands",
              "parameters"
            ]
          }
        },
        {
          "NAME": "ctBoat",
          "CLASS": "CONSTRAINT",
          "KIND": "LINEAR",
          "SCHEMA": {
            "NAMES": [
              "Name",
              "period",
              "Row",
              "Sense",
              "RHS",
              "dual"
            ],
            "KIND": [
              "STRING",
              "INTEGER",
              "STRING",
              "STRING",
              "DOUBLE",
              "DOUBLE"
            ],
            "KEYS": [
              "Name",
              "period"
            ],
            "FOREIGN_KEYS": [
              {
                "period": "demands.period"
              }
            ],
            "RELATIONSHIPS": [
              {
                "RHS": "demands.demand"
              }
            ]
          },
          "QUERY": {
            "SELECT": [
              "'ctBoat' AS Name                             -- STRING",
              "demands.period AS period                     -- INTEGER",
              "CONCAT('ctBoat','_', demands.period) AS Row  -- STRING",
              "'==' AS Sense                                -- STRING",
              "demands.demand - inventory.ancestor AS RHS   -- DOUBLE",
              "'DualValue(Row)' AS dual                    -- DOUBLE_FUNCTION",
              "CAST(1.0 AS DOUBLE) AS regular_coeff        -- DOUBLE",
              "CAST(1.0 AS DOUBLE) AS extra_coeff          -- DOUBLE ",
              "CAST(1.0 AS DOUBLE) AS inventory_coeff      -- DOUBLE "
            ],
            "FROM": [
              "demands"
            ],
            "WHERE": [
              "ancestor = SELECT( ancestor from demands USING (period))"
            ]
          }
        },
        {
          "NAME": "ctCost",
          "CLASS": "CONSTRAINT",
          "KIND": "LINEAR",
          "SCHEMA": {
            "NAME": [
              "Name",
              "period",
              "Row",
              "Constant",
              "Sense",
              "Value"
            ],
            "KIND": [
              "STRING",
              "INTEGER",
              "STRING",
              "DOUBLE",
              "STRING",
              "DOUBLE_FUNCTION"
            ],
            "KEYS": [
              "Name",
              "period"
            ],
            "FOREIGN_KEYS": [
              {
                "period": "demand.period"
              }
            ],
            "RELATIONSHIPS": [
              {
                "regular_coeff": "parameters.regularCost"
              },
              {
                "extra_coeff": "parameters.extraCost"
              },
              {
                "inventory_coeff": "parameters.inventoryCost"
              }
            ]
          },
          "QUERY": {
            "SELECT": [
              "'ctCost' AS Name                     -- STRING",
              "demands.period AS period                  -- INTEGER",
              "CONCAT('ctCost','_', demands.period) AS Row  -- STRING",
              "'==' AS Sense                            -- STRING",
              "CAST(0.0 AS DOUBLE)  AS RHS               -- DOUBLE",
              "'DualValue(Row)' AS dual                -- DOUBLE_FUNCTION",
              "CAST(1.0 AS DOUBLE) AS cost_coeff          -- DOUBLE ",
              "parameters.regularCost AS regular_coeff    -- DOUBLE",
              "parameters.extraCost AS extra_coeff    -- DOUBLE",
              "parameters.inventoryCost AS inventory_coeff    -- DOUBLE"
            ],
            "FROM": [
              "demands",
              "parameters"
            ]
          }
        },
        {
          "NAME": "production",
          "CLASS": "DATA",
          "KIND": "OUTPUT",
          "SCHEMA": {
            "NAME": [
              "period",
              "regular",
              "extra",
              "inventory",
              "marginalCapacityValue"
            ],
            "KIND": [
              "INTEGER",
              "DOUBLE",
              "DOUBLE",
              "DOUBLE",
              "DOUBLE"
            ],
            "KEYS": [
              "period"
            ],
            "FOREIGN_KEYS": [
              {
                "period": "demands.period"
              }
            ],
            "RELATIONSHIPS": [
              {
                "regular": "regular.value"
              },
              {
                "extra": "extra.value"
              },
              {
                "inventory": "inventory.value"
              },
              {
                "marginalCapacityValue": "ctCapacity.dual"
              }
            ]
          },
          "QUERY": {
            "SELECT": [
              "demands.period AS period",
              "regular.Value AS regular",
              "extra.Value AS extra",
              "inventory.Value AS inventory",
              "ctCapacity.dual AS marginalCapacityValue"
            ],
            "FROM": [
              "demands"
            ],
            "JOIN": [
              "regular"
            ],
            "USING": [
              "(period)"
            ],
            "JOIN#2": [
              "extra"
            ],
            "USING#2": [
              "(period)"
            ],
            "JOIN#3": [
              "inventory"
            ],
            "USING#3": [
              "(period)"
            ],
            "JOIN#4": [
              "ctCapacity"
            ],
            "USING#4": [
              "(period)"
            ]
          }
        }
      ]
    }
  ]
}
